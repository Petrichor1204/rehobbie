# Rehobbie — environment variables
# Copy this file to `.env.local` and fill in the values. NEVER put real secrets
# in THIS file — it is committed to git. Real values belong in `.env.local`.
#
# Every integration is OPTIONAL: with a key missing, that feature simply no-ops
# (anonymous sessions skip, analytics skip, the AI plan falls back to the local
# generator), so the app always runs.

# ── Supabase (Step 6: anonymous sessions) ────────────────────────────────────
# Project Settings → API. Enable "Anonymous sign-ins" under Authentication.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── PostHog (Step 7: product analytics) ──────────────────────────────────────
# Project Settings → API keys. Host is region-specific (us.i / eu.i).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── AI recovery plan (Step 9) ────────────────────────────────────────────────
# Pick ONE provider. Server-side only — never exposed to the browser.
# If neither is set, the dashboard uses the built-in local plan generator.

# Option A — GitHub Models (free, no Azure quota). Recommended for hackathons.
#   Create a fine-grained PAT with the "models: read" permission:
#   https://github.com/settings/personal-access-tokens
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# Option B — Microsoft Foundry IQ / Azure OpenAI (used only if GITHUB_MODELS_TOKEN is empty).
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_DEPLOYMENT=
AZURE_FOUNDRY_API_VERSION=2024-08-01-preview
