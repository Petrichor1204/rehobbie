# Rehobbie — environment variables
# Copy this file to `.env.local` and fill in the values. NEVER put real secrets
# in THIS file — it is committed to git. Real values belong in `.env.local`.
#
# Every integration is OPTIONAL: with a key missing, that feature simply no-ops
# (anonymous sessions skip, the AI plan falls back to the local generator),
# so the app always runs.

# ── Supabase (Step 6: anonymous sessions) ────────────────────────────────────
# Project Settings → API. Enable "Anonymous sign-ins" under Authentication.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── AI recovery plan (Step 9) ────────────────────────────────────────────────
# Server-side only — never exposed to the browser.
# If nothing here is set, the dashboard uses the built-in local plan generator.

# Microsoft Foundry (Azure AI Foundry) — PRIMARY / required path. Takes priority.
#   ENDPOINT  = resource base. Two shapes are auto-detected:
#     - https://<resource>.services.ai.azure.com   (Foundry "Models", incl.
#                                                    Direct-from-Azure models e.g. Grok)
#     - https://<resource>.openai.azure.com        (Azure OpenAI deployments)
#     (If you only have the project endpoint .../api/projects/<name>, just paste
#      it — the /api/projects/... suffix is stripped automatically.)
#   DEPLOYMENT = the deployment/model name you chose, e.g. grok-4-1-fast-non-reasoning
#   API_VERSION is optional (defaults: 2024-05-01-preview for services.ai, else 2024-08-01-preview)
#   JSON_MODE   set to "false" if a model rejects response_format json_object
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_DEPLOYMENT=
AZURE_FOUNDRY_API_VERSION=
AZURE_FOUNDRY_JSON_MODE=true

# GitHub Models — OPTIONAL dev fallback only (NOT Microsoft Foundry). Used only
# when the AZURE_FOUNDRY_* vars above are empty.
#   PAT with "models: read": https://github.com/settings/personal-access-tokens
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini
